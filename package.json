{
  "name": "shopee-review",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "dotenv -e .env -- pnpm --filter @app/database generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @app/database migrate:dev",
    "db:deploy": "dotenv -e .env -- pnpm --filter @app/database migrate:deploy",
    "db:seed": "dotenv -e .env -- pnpm --filter @app/database seed"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.28.2"
}
