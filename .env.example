# Host dev: point directly at Postgres.
# Docker/prod: point DATABASE_URL at pgBouncer (transaction mode) and set DIRECT_URL to Postgres:
#   DATABASE_URL=postgresql://shopee_review:<pass>@pgbouncer:6432/shopee_review?pgbouncer=true&connection_limit=1
#   DIRECT_URL=postgresql://shopee_review:<pass>@postgres:5432/shopee_review
DATABASE_URL=postgresql://shopee_review:shopee_review_dev@localhost:65432/shopee_review
# Direct (non-pooled) connection for migrations/introspection. Equals DATABASE_URL on host dev.
DIRECT_URL=postgresql://shopee_review:shopee_review_dev@localhost:65432/shopee_review
PORT=3066
NODE_ENV=development
# REQUIRED: docker-compose refuses to boot if unset (no insecure fallback).
# Use a long random string (e.g. `openssl rand -base64 48`). Must match across
# backend + frontend (the Next middleware verifies the same HS256 token).
JWT_SECRET=change-me-to-random-string-min-32-chars
# Auth cookie Secure flag. MUST be 'true' in production *behind HTTPS* (browsers
# reject Secure cookies over plain HTTP → login breaks). Leave false for HTTP.
COOKIE_SECURE=false

# Domain (production): set to your actual domain, e.g. review.example.com
# Used by Traefik (Coolify proxy) to route traffic → nginx
DOMAIN=localhost

# Frontend / API URLs
# Browser uses a RELATIVE /api base (same-origin via nginx) — no public API URL
# is baked into the client bundle, so one image runs on any host/port.
# API_INTERNAL_URL is server-only (SSR → backend); set to the backend origin.
API_INTERNAL_URL=http://localhost:3066/api
# CORS + OAuth redirect origin(s), comma-separated. Match how you reach the app
# (e.g. http://localhost:8081 for local docker via nginx).
FRONTEND_URL=http://localhost:5166

# Google OAuth (Phase 02)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3066/api/auth/google/callback
# Facebook login — create an app at developers.facebook.com, add "Facebook Login",
# request the `email` permission. Leave blank to disable the Facebook button.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3066/api/auth/facebook/callback

# Email verification via Resend (Phase 02)
RESEND_API_KEY=
MAIL_FROM=shopee.review <onboarding@resend.dev>

# Cloudflare R2 image uploads (Phase 05)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shopee-review-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Shopee affiliate (optional). If unset, scrape degrades to the plain product
# URL as the suggested affiliate link (users paste their own to earn commission).
SHOPEE_AFFILIATE_ID=

# First-admin bootstrap: comma-separated usernames granted is_admin on backend
# startup (idempotent). No self-promotion UI — set this once for your account.
ADMIN_BOOTSTRAP_USERNAME=

# Redis — cache store, BullMQ queues, and Socket.io adapter backend.
# Host dev: leave empty (cache falls back to in-memory; queues/sockets degrade gracefully).
# Docker/prod: redis://redis:6379  (REQUIRED for BullMQ + Socket.io multi-instance).
REDIS_URL=

# Admin token guarding the Bull Board queue dashboard (/admin/queues).
# Required when REDIS_URL is set (queues active). Use a long random string.
ADMIN_TOKEN=

# Meilisearch — primary search engine. Leave MEILI_HOST empty to use the
# PostgreSQL full-text fallback (host dev). Docker/prod: http://meilisearch:7700
MEILI_HOST=
MEILI_MASTER_KEY=masterKeyChangeMe

# Sentry error tracking (optional — no-op when unset)
# Backend reads SENTRY_DSN; frontend reads NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Only needed to upload source maps during frontend production builds:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Observability (Phase 08). Backend exposes Prometheus metrics at /metrics and
# logs structured JSON (Pino) in production. LOG_LEVEL: trace|debug|info|warn|error.
LOG_LEVEL=
# Grafana admin password for the monitoring stack (docker-compose.monitoring.yml).
GRAFANA_PASSWORD=admin

# HTTPS / TLS (Let's Encrypt via the certbot service). Set these, point DNS at
# the host, then follow nginx/conf.d/app-tls.conf.disabled to enable TLS.
DOMAIN=
CERTBOT_EMAIL=
