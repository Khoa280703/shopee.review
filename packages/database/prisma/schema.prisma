generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations/introspection. When DATABASE_URL
  // points at pgBouncer (transaction mode), Prisma uses DIRECT_URL for DDL.
  // Falls back to DATABASE_URL when DIRECT_URL is unset (host dev).
  directUrl = env("DIRECT_URL")
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  MENTION
  NEW_POST
}

enum ReportReason {
  SPAM
  SCAM
  OFFENSIVE
  FAKE
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  POST
  COMMENT
  USER
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

model User {
  id              Int       @id @default(autoincrement())
  username        String    @unique @db.VarChar(50)
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  googleId        String?   @unique @map("google_id")
  facebookId      String?   @unique @map("facebook_id")
  displayName     String    @map("display_name") @db.VarChar(100)
  bio             String?   @db.Text
  avatarUrl       String?   @map("avatar_url")
  emailVerified   Boolean   @default(false) @map("email_verified")
  verifyToken     String?   @unique @map("verify_token")
  verifyTokenExp  DateTime? @map("verify_token_exp")
  resetToken      String?   @unique @map("reset_token")
  resetTokenExp   DateTime? @map("reset_token_exp")
  // Bumped on password reset/change and ban → invalidates all prior JWTs.
  tokenVersion    Int       @default(0) @map("token_version")
  affiliateId     String?   @map("affiliate_id") @db.VarChar(100)
  totalClicks     Int       @default(0) @map("total_clicks")
  followersCount  Int       @default(0) @map("followers_count")
  followingCount  Int       @default(0) @map("following_count")
  isAdmin         Boolean   @default(false) @map("is_admin")
  bannedAt        DateTime? @map("banned_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  posts              Post[]
  reactions          Reaction[]
  bookmarks          Bookmark[]
  comments           Comment[]
  followers          Follow[]       @relation("Following")
  following          Follow[]       @relation("Follower")
  notifications      Notification[] @relation("Recipient")
  actedNotifications Notification[] @relation("Actor")
  reports            Report[]       @relation("Reporter")
  blocking           Block[]        @relation("Blocker")
  blockedBy          Block[]        @relation("Blocked")
  sessions           Session[]

  @@map("users")
}

// One row per login (device/browser). The JWT carries this row's id (`sid`);
// deleting the row revokes that session (checked in JwtStrategy). Enables the
// "active sessions" list + per-device logout without a stateful session store.
model Session {
  id        String   @id @default(cuid())
  userId    Int      @map("user_id")
  userAgent String?  @map("user_agent") @db.VarChar(400)
  ip        String?  @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Post {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  title        String   @db.VarChar(200)
  content      String?  @db.Text
  productUrl   String   @map("product_url")
  affiliateUrl String   @map("affiliate_url")
  productMeta  Json?    @map("product_meta")
  images       String[]
  categoryId   Int?     @map("category_id")
  likeCount    Int      @default(0) @map("like_count") // total reactions (all types)
  commentCount Int      @default(0) @map("comment_count")
  clickCount   Int      @default(0) @map("click_count")
  shareCount   Int      @default(0) @map("share_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reactions     Reaction[]
  bookmarks     Bookmark[]
  comments      Comment[]
  clickLogs     ClickLog[]
  notifications Notification[]

  @@index([userId])
  @@index([categoryId])
  @@index([createdAt(sort: Desc)])
  // Keyset pagination for the sortable feeds (findAll sortBy=likeCount|clickCount
  // with an id tiebreaker) — keeps the sort index-backed instead of a full sort.
  @@index([likeCount(sort: Desc), id(sort: Desc)])
  @@index([clickCount(sort: Desc), id(sort: Desc)])
  @@map("posts")
}

model Follow {
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
  @@map("follows")
}

model Reaction {
  userId    Int          @map("user_id")
  postId    Int          @map("post_id")
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId, type])
  @@map("reactions")
}

model Bookmark {
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("bookmarks")
}

model Comment {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  parentId  Int?     @map("parent_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("Replies")

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@index([postId, parentId])
  @@map("comments")
}

model ClickLog {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  ip        String?
  userAgent String?  @map("user_agent")
  referer   String?
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([createdAt])
  // Serves the 1h/IP dedup lookup (postId + ip + createdAt window) index-only.
  @@index([postId, ip, createdAt])
  @@map("click_logs")
}

model Notification {
  id          Int              @id @default(autoincrement())
  recipientId Int              @map("recipient_id")
  type        NotificationType
  actorId     Int              @map("actor_id")
  postId      Int?             @map("post_id")
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now()) @map("created_at")

  recipient User  @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User  @relation("Actor", fields: [actorId], references: [id], onDelete: Cascade)
  post      Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([recipientId, read])
  @@index([createdAt])
  @@map("notifications")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts Post[]

  @@map("categories")
}

model Report {
  id         Int              @id @default(autoincrement())
  reporterId Int              @map("reporter_id")
  targetType ReportTargetType @map("target_type")
  targetId   Int              @map("target_id") // post/comment/user id per targetType (polymorphic, no FK)
  reason     ReportReason
  detail     String?          @db.VarChar(500)
  status     ReportStatus     @default(PENDING)
  resolvedBy Int?             @map("resolved_by")
  createdAt  DateTime         @default(now()) @map("created_at")

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, targetType, targetId]) // idempotent reporting
  @@index([status, createdAt])
  @@map("reports")
}

model Block {
  blockerId Int      @map("blocker_id")
  blockedId Int      @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model ScrapedProduct {
  id         Int      @id @default(autoincrement())
  productUrl String   @unique @map("product_url")
  data       Json
  scrapedAt  DateTime @default(now()) @map("scraped_at")

  @@index([scrapedAt])
  @@map("scraped_products")
}

// Append-only trail of privileged admin actions (ban/unban/delete/resolve) for
// moderation accountability. actorId/targetId are polymorphic (no FK) so history
// survives even if the actor or target row is later deleted — the point of an
// audit log is that it cannot be erased by deleting the referenced entity.
model AdminAuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int      @map("actor_id")
  action     String   @db.VarChar(50) // e.g. BAN_USER, DELETE_POST, RESOLVE_REPORT
  targetType String?  @map("target_type") @db.VarChar(20) // USER | POST | COMMENT | REPORT
  targetId   Int?     @map("target_id")
  detail     String?  @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@map("admin_audit_logs")
}
